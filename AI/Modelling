"""## Arsitektur TextCNN (Multi-Input)"""

def build_textcnn_model(vocab_size, max_len, embed_dim, num_filters,
                        kernel_sizes, dense_units, dropout_rate, num_features,
                        weight_0, weight_1, learning_rate, confidence_penalty=0.1):
    reg = tf.keras.regularizers.l2(1e-4)

    input_teks = tf.keras.Input(shape=(1,), dtype=tf.string, name='input_teks')
    x = text_layer(input_teks)
    x = tf.keras.layers.Embedding(
        input_dim=vocab_size + 1, output_dim=embed_dim,
        mask_zero=False, embeddings_regularizer=reg, name='embedding'
    )(x)
    x = tf.keras.layers.Dropout(dropout_rate * 0.5, name='embed_dropout')(x)

    conv_outputs = []
    for k in kernel_sizes:
        conv = tf.keras.layers.Conv1D(
            filters=num_filters, kernel_size=k, activation='relu',
            padding='same', kernel_regularizer=reg, name=f'conv_{k}gram'
        )(x)
        pool = tf.keras.layers.GlobalMaxPooling1D(name=f'pool_{k}gram')(conv)
        conv_outputs.append(pool)

    x_teks = tf.keras.layers.Concatenate(name='concat_conv')(conv_outputs)
    x_teks = tf.keras.layers.Dense(dense_units, activation='relu',
                                   kernel_regularizer=reg, name='dense_teks')(x_teks)
    x_teks = tf.keras.layers.Dropout(dropout_rate, name='dropout_teks')(x_teks)

    input_num = tf.keras.Input(shape=(num_features,), dtype=tf.float32, name='input_num')
    x_num = tf.keras.layers.BatchNormalization(name='batch_norm')(input_num)
    x_num = tf.keras.layers.Dense(64, activation='relu', name='dense_num_1')(x_num)
    x_num = tf.keras.layers.Dense(32, activation='relu', name='dense_num_2')(x_num)

    x = tf.keras.layers.Concatenate(name='concatenate')([x_teks, x_num])
    x = tf.keras.layers.Dense(256, activation='relu',
                               kernel_regularizer=reg, name='dense_gabung')(x)
    x = tf.keras.layers.Dropout(dropout_rate, name='dropout_final')(x)
    x = tf.keras.layers.Dense(64, activation='relu', name='dense_final')(x)
    output = tf.keras.layers.Dense(1, activation='sigmoid', name='output')(x)

    model = tf.keras.Model(inputs=[input_teks, input_num], outputs=output,
                           name='smishing_textcnn')
    model.compile(
        optimizer=tf.keras.optimizers.Adam(learning_rate=learning_rate),
        loss=WeightedBinaryCrossentropy(weight_0, weight_1, label_smoothing=0.0, confidence_penalty=confidence_penalty),
        metrics=['accuracy',
                 tf.keras.metrics.Precision(name='precision'),
                 tf.keras.metrics.Recall(name='recall'),
                 tf.keras.metrics.AUC(name='auc')]
    )
    return model

