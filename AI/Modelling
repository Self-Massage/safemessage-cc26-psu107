"""## WeightedBinaryCrossentropy"""

@tf.keras.utils.register_keras_serializable(package='Custom', name='WeightedBinaryCrossentropy')
class WeightedBinaryCrossentropy(tf.keras.losses.Loss):
    def __init__(self, weight_0=1.0, weight_1=1.2,
                 label_smoothing=0.0,
                 confidence_penalty=0.0,   # ← TAMBAH
                 **kwargs):
        super().__init__(**kwargs)
        self.weight_0           = weight_0
        self.weight_1           = weight_1
        self.label_smoothing    = label_smoothing
        self.confidence_penalty = confidence_penalty

    def call(self, y_true, y_pred):
        y_pred = tf.reshape(y_pred, [-1])
        y_true = tf.reshape(tf.cast(y_true, tf.float32), [-1])
        eps    = self.label_smoothing
        y_true_smooth = y_true * (1.0 - eps) + 0.5 * eps
        y_pred_clipped = tf.clip_by_value(y_pred, 1e-7, 1 - 1e-7)
        bce     = -(y_true_smooth * tf.math.log(y_pred_clipped) +
                    (1 - y_true_smooth) * tf.math.log(1 - y_pred_clipped))
        weights = y_true * self.weight_1 + (1 - y_true) * self.weight_0
        loss_bce = tf.reduce_mean(weights * bce)

        # Confidence penalty
        entropy = -(y_pred_clipped * tf.math.log(y_pred_clipped) +
                    (1 - y_pred_clipped) * tf.math.log(1 - y_pred_clipped))
        loss_conf = self.confidence_penalty * tf.reduce_mean(entropy)

        return loss_bce + loss_conf

    def get_config(self):
        config = super().get_config()
        config.update({
            'weight_0'           : self.weight_0,
            'weight_1'           : self.weight_1,
            'label_smoothing'    : self.label_smoothing,
            'confidence_penalty' : self.confidence_penalty,
        })
        return config

    @classmethod
    def from_config(cls, config): return cls(**config)

"""## F1MonitorCallback
> Callback `DomainBreakdownCallback` digunakan untuk melaporkan MAE dan F1
> secara terpisah untuk domain SMS dan email setiap epoch.
> Kalau F1 SMS jauh di bawah F1 email, maka model masih bias ke email.
"""

class F1MonitorCallback(tf.keras.callbacks.Callback):
    def __init__(self, val_data, threshold=0.5, patience=15,
                 model_path='smishing_model_best.keras',
                 target_mae=0.02, **kwargs):
        super().__init__(**kwargs)
        self.X_val, self.y_val = val_data
        self.threshold  = threshold
        self.patience   = patience
        self.model_path = model_path
        self.target_mae = target_mae
        self.best_f1    = 0.0
        self.best_mae   = 999.0
        self.wait       = 0
        self.best_epoch = 0
        self.history_f1 = []

    def on_epoch_end(self, epoch, logs=None):
        y_prob = self.model.predict(self.X_val, verbose=0).flatten()
        y_pred = (y_prob >= self.threshold).astype(int)

        f1   = f1_score(self.y_val, y_pred, zero_division=0)
        prec = precision_score(self.y_val, y_pred, zero_division=0)
        rec  = recall_score(self.y_val, y_pred, zero_division=0)
        mae  = float(np.mean(np.abs(self.y_val - y_pred.astype(float))))

        logs['val_f1']  = f1
        logs['val_mae'] = mae
        self.history_f1.append(f1)

        mae_icon = '✅' if mae <= self.target_mae else '❌'
        print(f'  → F1={f1:.4f} | P={prec:.4f} | R={rec:.4f} | '
              f'MAE={mae:.4f} {mae_icon} (target≤{self.target_mae})')

        # Simpan model jika F1 bagus DAN MAE membaik
        improved = (f1 >= 0.85 and mae < self.best_mae)
        if improved:
            self.best_f1    = f1
            self.best_mae   = mae
            self.best_epoch = epoch + 1
            self.wait       = 0
            self.model.save(self.model_path)
            print(f'  ✅ Best model saved (F1={f1:.4f}, MAE={mae:.4f}) → {self.model_path}')
        else:
            self.wait += 1
            if self.wait >= self.patience:
                self.model.stop_training = True
                print(f'Early stop. Best MAE={self.best_mae:.4f} @ epoch {self.best_epoch}')
            else:
                print(f'No improve ({self.wait}/{self.patience})')

class DomainBreakdownCallback(tf.keras.callbacks.Callback):
    """
    Hitung MAE dan F1 terpisah untuk SMS vs email setiap N epoch.
    Kalau val_f1_sms << val_f1_email, maka model masih bias domain email.
    """

    def __init__(self, df_val, X_val_teks_tf, X_val_num, y_val,
                 threshold=0.5, every_n=5, **kwargs):
        super().__init__(**kwargs)
        self.df_val       = df_val.reset_index(drop=True)
        self.X_val_teks   = X_val_teks_tf
        self.X_val_num    = X_val_num
        self.y_val        = y_val
        self.threshold    = threshold
        self.every_n      = every_n
        self.history      = []

        # Membuat mask domain
        self.mask_sms   = df_val['sumber'].str.contains('kaggle', na=False).values == False
        self.mask_email = ~self.mask_sms

    def on_epoch_end(self, epoch, logs=None):
        if (epoch + 1) % self.every_n != 0:
            return

        y_prob = self.model.predict(
            [self.X_val_teks, self.X_val_num], verbose=0
        ).flatten()
        y_pred = (y_prob >= self.threshold).astype(int)

        results = {}
        for name, mask in [('SMS', self.mask_sms), ('Email', self.mask_email)]:
            if mask.sum() == 0:
                continue
            yp  = y_prob[mask]
            yt  = self.y_val[mask]
            ypd = y_pred[mask]
            mae = float(np.mean(np.abs(yt - yp)))
            f1  = f1_score(yt, ypd, zero_division=0)
            results[name] = {'mae': mae, 'f1': f1, 'n': int(mask.sum())}

        self.history.append({'epoch': epoch + 1, **results})

        print(f'Domain Breakdown (epoch {epoch+1}):')
        for domain, m in results.items():
            flag = ''
            if domain == 'SMS' and m['f1'] < 0.75:
                flag = ' ⚠️ F1 SMS rendah!'
            print(f'     {domain:6s} n={m["n"]:4d} | MAE={m["mae"]:.4f} | F1={m["f1"]:.4f}{flag}')

        # Gap peringatan
        if 'SMS' in results and 'Email' in results:
            gap = results['Email']['f1'] - results['SMS']['f1']
            if gap > 0.10:
                print(f'  ⚠️  F1 gap (Email-SMS) = {gap:.4f} > 0.10 → bias domain masih ada!')

