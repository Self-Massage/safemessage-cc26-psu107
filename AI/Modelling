"""## Custom Training Loop — tf.GradientTape"""

def make_dataset(X_teks, X_num, y, batch_size, shuffle=False):
    ds = tf.data.Dataset.from_tensor_slices(
        ({'input_teks': X_teks, 'input_num': X_num}, y)
    )
    if shuffle:
        ds = ds.shuffle(buffer_size=len(y), seed=42)
    return ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)

train_ds = make_dataset(X_train_teks_tf, X_train_num, y_train, BATCH_SIZE, shuffle=True)
val_ds   = make_dataset(X_val_teks_tf,   X_val_num,   y_val,   BATCH_SIZE)

model_gt       = build_textcnn_model(
    vocab_size=VOCAB_SIZE, max_len=MAX_LEN, embed_dim=EMBED_DIM,
    num_filters=NUM_FILTERS, kernel_sizes=KERNEL_SIZES, dense_units=DENSE_UNITS,
    dropout_rate=DROPOUT_RATE, num_features=len(FITUR_NUMERIK),
    weight_0=CLASS_WEIGHT_0, weight_1=CLASS_WEIGHT_1, learning_rate=LEARNING_RATE
)
optimizer_gt      = tf.keras.optimizers.Adam(learning_rate=LEARNING_RATE)
loss_fn_gt        = WeightedBinaryCrossentropy(CLASS_WEIGHT_0, CLASS_WEIGHT_1)
train_loss_metric = tf.keras.metrics.Mean(name='train_loss')
train_acc_metric  = tf.keras.metrics.BinaryAccuracy(name='train_acc')
val_loss_metric   = tf.keras.metrics.Mean(name='val_loss')
val_acc_metric    = tf.keras.metrics.BinaryAccuracy(name='val_acc')

@tf.function
def train_step_gt(X_batch, y_batch):
    with tf.GradientTape() as tape:
        y_pred = model_gt(X_batch, training=True)
        loss   = loss_fn_gt(y_batch, y_pred)
    grads, _ = tf.clip_by_global_norm(tape.gradient(loss, model_gt.trainable_variables), 1.0)
    optimizer_gt.apply_gradients(zip(grads, model_gt.trainable_variables))
    train_loss_metric.update_state(loss)
    train_acc_metric.update_state(y_batch, y_pred)

@tf.function
def val_step_gt(X_batch, y_batch):
    y_pred = model_gt(X_batch, training=False)
    val_loss_metric.update_state(loss_fn_gt(y_batch, y_pred))
    val_acc_metric.update_state(y_batch, y_pred)
    return y_pred

EPOCHS_GT   = 50
PATIENCE_GT = 7
best_f1_gt  = 0.0
