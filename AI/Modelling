def predict_smishing(text: str, num_features: list = None) -> dict:
    if num_features is None:
        t_bersih = _re.sub(r'http\S+|www\.\S+', '[URL]', text)
        t_bersih = _re.sub(r'\b\d{10,}\b', '[NOMOR_PANJANG]', t_bersih)
        t_bersih = _re.sub(
            r'(?i)\b(kode|verifikasi|otp|pin|token|nomor|no|code|verification)([\s:]*)\d{4,6}\b',
            r'\1\2[KODE]', t_bersih
        )
        num_features = [
            len(text), len(text.split()), text.count('!'),
            1 if '[URL]'           in t_bersih else 0,
            1 if '[NOMOR_PANJANG]' in t_bersih else 0,
            1 if '[KODE]'          in t_bersih else 0,
            sum(1 for c in text if c.isupper()) / max(len(text), 1)
        ]

    with open('model_config.json') as f:
        cfg = json.load(f)
    threshold = cfg.get('threshold', 0.5)

    input_teks = tf.constant([[str(text)]], dtype=tf.string)
    input_num  = np.array([num_features], dtype='float32')
    prob       = float(best_model.predict([input_teks, input_num], verbose=0).flatten()[0])
    label      = 'PHISHING' if prob >= threshold else 'NORMAL'
    conf       = prob if prob >= threshold else 1 - prob

    return {
        'risk_score' : round(prob, 4),
        'label'      : label,
        'confidence' : f'{conf*100:.1f}%',
        'is_phishing': bool(prob >= threshold),
        'threshold'  : threshold
    }


