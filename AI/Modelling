# Domain mask untuk breakdown
mask_sms_val   = df_val['sumber'].str.contains('kaggle', na=False).values == False
mask_email_val = ~mask_sms_val

print('Custom Training Loop (tf.GradientTape)...')
print('='*65)

for epoch in range(EPOCHS_GT):
    for m in [train_loss_metric, train_acc_metric, val_loss_metric, val_acc_metric]:
        m.reset_state()

    for X_batch, y_batch in train_ds:
        train_step_gt(X_batch, y_batch)

    y_prob_all = []
    for X_batch, y_batch in val_ds:
        y_prob_all.append(val_step_gt(X_batch, y_batch).numpy().flatten())

    y_prob_gt = np.concatenate(y_prob_all)
    y_pred_gt = (y_prob_gt >= 0.5).astype(int)
    f1_gt     = f1_score(y_val, y_pred_gt, zero_division=0)
    mae_gt = float(np.mean(np.abs(y_val - y_pred_gt.astype(float))))

    history_gt['train_loss'].append(float(train_loss_metric.result()))
    history_gt['train_acc'].append(float(train_acc_metric.result()))
    history_gt['val_loss'].append(float(val_loss_metric.result()))
    history_gt['val_acc'].append(float(val_acc_metric.result()))
    history_gt['val_f1'].append(f1_gt)
    history_gt['val_mae'].append(mae_gt)

    # Domain breakdown setiap 5 epoch
    domain_info = ''
    if (epoch + 1) % 5 == 0:
        mae_sms   = float(np.mean(np.abs(y_val[mask_sms_val]   - y_pred_gt[mask_sms_val].astype(float))))
        mae_email = float(np.mean(np.abs(y_val[mask_email_val] - y_pred_gt[mask_email_val].astype(float))))
        f1_sms    = f1_score(y_val[mask_sms_val],   y_pred_gt[mask_sms_val],   zero_division=0) if mask_sms_val.sum()   > 0 else 0
        f1_email  = f1_score(y_val[mask_email_val], y_pred_gt[mask_email_val], zero_division=0) if mask_email_val.sum() > 0 else 0
        domain_info = f' | SMS_MAE={mae_sms:.4f} F1={f1_sms:.4f} | Email_MAE={mae_email:.4f} F1={f1_email:.4f}'

    print(f'Epoch {epoch+1}/{EPOCHS_GT} | loss={history_gt["train_loss"][-1]:.4f} | '
          f'val_loss={history_gt["val_loss"][-1]:.4f} | val_f1={f1_gt:.4f} | val_mae={mae_gt:.4f}'
          + domain_info)

    if f1_gt > best_f1_gt:
        best_f1_gt    = f1_gt
        best_epoch_gt = epoch + 1
